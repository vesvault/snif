. /etc/snif.conf
BaseDir=$SNIF_CA_PROXY
CertDir="$BaseDir/crt"
ArcDir="$BaseDir/arc"

mkdir -m 0775 $ArcDir 2> /dev/null

ArcDay=$ArcDir/`date +%Y%m%d`

mkdir -m 0775 $ArcDay 2> /dev/null

find $CertDir/ -name "*.crt" -mtime +75 -exec mv \{\} $ArcDay/ \;

rmdir --ignore-fail-on-non-empty $ArcDay
